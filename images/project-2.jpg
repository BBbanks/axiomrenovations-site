<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400">
  <defs>
    <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e0d5c7;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#c4b5a3;stop-opacity:1" />
    </linearGradient>
    <pattern id="wood" x="0" y="0" width="80" height="40" patternUnits="userSpaceOnUse">
      <rect x="0" y="0" width="80" height="40" fill="#d4c2ae"/>
      <line x1="0" y1="0" x2="80" y2="0" stroke="#c2b09c" stroke-width="1"/>
      <line x1="0" y1="20" x2="80" y2="20" stroke="#c2b09c" stroke-width="1"/>
    </pattern>
  </defs>
  <rect width="600" height="400" fill="url(#grad2)"/>
  <rect x="60" y="60" width="480" height="280" fill="url(#wood)"/>
  <text x="300" y="200" font-family="Inter, sans-serif" font-size="48" font-weight="600" fill="#8d806d" text-anchor="middle" dy=".3em">Interior Renovation</text>
  <text x="300" y="250" font-family="Inter, sans-serif" font-size="24" fill="#5c564e" text-anchor="middle" dy=".3em">Cape Coral Project</text>
</svg>