<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400">
  <defs>
    <linearGradient id="grad3" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e8dcc8;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#cbbda5;stop-opacity:1" />
    </linearGradient>
    <pattern id="detail" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
      <circle cx="50" cy="50" r="8" fill="#9b8d7a"/>
      <circle cx="20" cy="20" r="4" fill="#8d806d"/>
      <circle cx="80" cy="80" r="4" fill="#8d806d"/>
    </pattern>
  </defs>
  <rect width="600" height="400" fill="url(#grad3)"/>
  <rect x="60" y="60" width="480" height="280" fill="url(#detail)"/>
  <text x="300" y="200" font-family="Inter, sans-serif" font-size="48" font-weight="600" fill="#8d806d" text-anchor="middle" dy=".3em">Repair & Finish Work</text>
  <text x="300" y="250" font-family="Inter, sans-serif" font-size="24" fill="#5c564e" text-anchor="middle" dy=".3em">Southwest Florida Project</text>
</svg>